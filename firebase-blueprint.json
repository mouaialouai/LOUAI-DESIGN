{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project entity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "titleEn": { "type": "string" },
        "titleAr": { "type": "string" },
        "descEn": { "type": "string" },
        "descAr": { "type": "string" },
        "clientEn": { "type": "string" },
        "clientAr": { "type": "string" },
        "imageUrl": { "type": "string" },
        "galleryImages": { "type": "array" },
        "tagsEn": { "type": "array" },
        "tagsAr": { "type": "array" },
        "specsEn": { "type": "array" },
        "specsAr": { "type": "array" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "category", "titleEn", "titleAr", "descEn", "descAr", "clientEn", "clientAr", "imageUrl"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all dynamic portfolio projects"
    }
  }
}
